link "code"
procedure main()
  local ax, bx
  ax := poly([term(Q(-2,1), 0), term(Q(1,1), 3)])
  bx := poly([term(Q(-3,1), 0), term(Q(2,1), 2)])
  write("mod_Q proc=", image(proc("mod_Q", 2)), "\n")
  write("mod_poly proc=", image(proc("mod_poly", 2)), "\n")
  write("type poly=", type(ax), "\n")
end
