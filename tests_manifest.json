      "md_line": 25,
      "body": "procedure FFT(N, a(x), omega, A);\nif N = 1\nthen\n{ Basis. } A_0 := a_0\nelse\nbegin\n{ Binary split. }\nn := N/2\nb(x) := sum_i=0^{n-1} a_2i x^i\nc(x) := sum_i=0^{n-1} a_2i+1 x^i\n{ Recursive calls. }\nFFT(n, b(x), omega2, B)\nFFT(n, c(x), omega2, C)\n{ Combine. }\nfor k := 0 until n - 1 do\nbegin\nA_k := B_k + omega_k times C_k\nA_k+n := B_k - omega_k times C_k\nend\nend",
      "expected": []
    },
