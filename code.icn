# --- catlist (list concat; Icon || is string-only) ---
procedure catlist(a, b)
  local r, i
  r := list(*a + *b)
  every i := 1 to *a do r[i] := a[i]
  every i := 1 to *b do r[i + *a] := b[i]
  return r
end

