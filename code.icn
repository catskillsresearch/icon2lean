procedure GCD(a, b)
  return (if equal(b, zero(b)) then normalize(a)
  else GCD(b, mod(a, b)))
end

# --- EUCLID (md line 2266) ---
procedure EUCLID(A, B)
  local q, a, s, t
  a := [copy(A), copy(B)]
  s := [one(A), zero(A)]
  t := [zero(A), one(A)]
  while not(equal(a[2], zero(A))) do {
  q := div(a[1], a[2])
  a := [a[2], ominus(a[1], times(a[2], q))]
  s := [s[2], ominus(s[1], times(s[2], q))]
  t := [t[2], ominus(t[1], times(t[2], q))] }
  return [normalize(a[1]), normalize(s[1]), normalize(t[1])]
end

# --- INVERSE (md line 2307) ---
procedure INVERSE(a, m)
  local gst
  gst := EUCLID(m, a)
  if unit(gst[1]) then return mod(div(gst[3], gst[1]), m)
  else pr{"ERROR: ", a, " inverse mod ", m, " does not exist"}
end

# --- CRA1 (md line 2347) ---
procedure CRA1(aa, bb, m)
  local a, b, g
  g := GCD(aa, m)
  if not divides(g, bb) then pr{"ERROR: no solution to linear congruence"}
  else { a := mod(aa, m); b := mod(bb, m)
  if equal(a, one(a)) then return b
  else if equal(b, zero(b)) then return zero(b)
  else if equal(a, b) then return one(b)
  else return div(plus(times(m, CRA1(m, -(b), a)), b), a) }
end

