# --- normalize_Q (md line 1404) ---
procedure normalize_Q(x)
  local g, top, bottom
  g := GCD(x.dividend, x.divisor)
  top := div(x.dividend, g)
  bottom := div(x.divisor, g)
  return (if negative(bottom) then Q(minus(top), minus(bottom))
  else Q(top, bottom))
end

