procedure div_Q(a, b)
  local zz
  zz := zero(b.dividend)
  if equal(b.dividend, zz) then pr{"ERROR: divide by 0 in Q"}
  else return (if equal(a.divisor, zz) then zero_Q(a)
  else normalize_Q(Q(times(a.dividend, b.divisor), times(b.dividend, a.divisor))))
end

# --- mod_Q (md line 1391) ---
procedure mod_Q(a, m)
