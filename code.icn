  c_coef := plus(ac, bc)
  if equal(c_coef, zero(c_coef))
  then plus_terms(rest(a), rest(b))
  else catlist([term(c_coef, ap)], plus_terms(rest(a), rest(b))) }
  else plus_terms(b, a) }
