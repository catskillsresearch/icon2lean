# --- NIA (md line 2706) ---
procedure NIA(ab_list)
  local ab_s, ab, a, b, Ux, Mx, c, sigma
  ab_s := copy(ab_list)
  ab := pop(ab_s); a := ab[1]; b := ab[2]
  Ux := poly_of(b)
  Mx := one(Ux)
  every k := 1 to *ab_s do {
  Mx := times(Mx, ominus(poly([term(one(b), 1)]), poly_of(a)))
  ab := pop(ab_s); a := ab[1]; b := ab[2]
  c := div(one(a), eval_poly(Mx, a))
  sigma := div(ominus(poly_of(b), poly_of(eval_poly(Ux, a))), poly_of(c))
  Ux := plus(Ux, times(sigma, Mx)) }
  return Ux
end

# --- FFT (md line 2734) ---
procedure FFT(N, ax, omega)
  local A, n, bx, cx, omega2, B, C, omega_k
  A := list(N, [])
  if N = 1 then {
  A[1] := zeroth_coef(ax)
  return A
  } else {
  n := N/2
  bx := poly_of_even_powered_terms(ax)
  cx := poly_of_odd_powered_terms(ax)
  omega2 := exp(omega, 2)
  B := FFT(n, bx, omega2)
  C := FFT(n, cx, omega2)
  every k := 1 to n do {
  omega_k := exp(omega, k - 1)
  A[k] := plus(B[k], times(omega_k, C[k]))
  A[k+n] := ominus(B[k], times(omega_k, C[k]))
  }
  return A
  }
end

# --- poly_of_even_powered_terms (md line 2765) ---
procedure poly_of_even_powered_terms(ax)
  local r
  r := []
  every t := !ax.terms
  do if mod_integer(t.power, 2) = 0 then push(r, term(t.coef, t.power/2))
  return poly(r)
end

# --- poly_of_odd_powered_terms (md line 2782) ---
procedure poly_of_odd_powered_terms(ax)
  local r
  r := []
  every t := !ax.terms
  do if mod_integer(t.power, 2) = 1 then push(r, term(t.coef, (t.power - 1)/2))
  if *r > 0 then return poly(r) else return zero(ax.terms[1])
end

