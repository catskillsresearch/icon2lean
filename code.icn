  a := fx.terms[1]
  return (if a.power = 0 then a.coef else zero(a.coef))
end

# --- lead_coef (md line 1622) ---
procedure lead_coef(ax)
  return (ax.terms[*ax.terms]).coef
end

# --- zero_poly (md line 1650) ---
procedure zero_poly(p)
