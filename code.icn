procedure div_poly(a, b)
  local n, m, r, q, quotient
  n := deg_poly(b)
  r := copy(a)
  quotient := zero_poly(r)
  repeat {
  m := deg_poly(r)
  if less_degree(m, n)
  then return quotient
  else { q := poly([term(div(lead_coef(r), lead_coef(b)), m - n)])
  if m = 0
  then return plus_poly(quotient, q)
  else { subtrahend := minus_poly(times_poly(q, b))
  r := plus_poly(r, subtrahend)
  quotient := plus_poly(quotient, q) } } }
end

