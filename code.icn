# --- plus_poly (md line 1740) ---
procedure plus_poly(a, b)
  local Terms, T, z
  Terms := plus_terms(a.terms, b.terms)
  T := []; z := zero(a.terms[1].coef)
  every t := !Terms do if not equal(t.coef, z) then T := catlist(T, [t])
  return (if *T > 0 then poly(T) else zero(a))
end

# --- plus_terms (md line 1756) ---
procedure plus_terms(a, b)
  local c_coef, at, ap, ac, bt, bp, bc
  return (
  if *a = 0 then b
  else if *b = 0 then a
  else {
  at := a[1]; ap := at.power; ac := at.coef
  bt := b[1]; bp := bt.power; bc := bt.coef
  if less(ap, bp)
  then {
  if equal(ac, zero(ac))
  then plus_terms(rest(a), b)
  else catlist([at], plus_terms(rest(a), b)) }
