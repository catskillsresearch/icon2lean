end

invocable all

# --- prs (md line 411) ---
procedure prs(x)
  every y := !x do print(@y)
end

# --- pr (md line 411) ---
procedure pr(x)
  (every y := !x do print(@y))
  write()
end

# --- print (md line 411) ---
procedure print(x)
  if type(x) == "list"
  then { writes("[")
  every y := !x[1:*x] do { print(y); writes(", ") }
  print(x[*x]); writes("]") }
  else if pp := proc("print_" || type(x), 1) then pp(x)
  else if type(x) == "string" then writes(x)
  else writes(image(x))
end

# --- record_base_B ---
record base_B(base, digits)

global Base, Width

procedure set_base(b, w)
  Base := b
  Width := if type(w) == "integer" & w > 0 then w else max(1, *("" || b) - 1)
end

# --- zero_base_B (md line 479) ---
procedure zero_base_B(x)
  return base_B(x.base, [0])
end

# --- one_base_B (md line 479) ---
procedure one_base_B(x)
  return base_B(x.base, [1])
end

# --- k_base_B (md line 479) ---
procedure k_base_B(x)
  return base_B(Base, digits_of(abs(x), Base))
end

# --- digits_of (md line 479) ---
procedure digits_of(x, B)
  if x < B then return [x] else return catlist(digits_of(x/B, B), [mod_integer(x, B)])
end

# --- plus_base_B (md line 497) ---
procedure plus_base_B(a, b)
  B := a.base
  return base_B(B, plus_digits(a.digits, b.digits, B))
end

# --- plus_digits (md line 510) ---
procedure plus_digits(ad, bd, B)
  local a, b, m, n, c_digits, gamma, t, i
  m := *ad; n := *bd
  if m < n then { a := catlist(list(n - m, 0), ad); b := bd }
  else if m > n then { a := ad; b := catlist(list(m - n, 0), bd) }
  else { a := ad; b := bd }
  m := *a;
  c_digits := list(m + 1, 0);
  gamma := 0
  every i := m to 1 by -1 do
  { t := a[i] + b[i] + gamma
  c_digits[i + 1] := mod_integer(t, B)
  gamma := t / B }
  c_digits[1] := gamma
  return normalize_digits(c_digits)
end

# --- ominus_base_B (md line 554) ---
procedure ominus_base_B(a, bb)
  b := copy(bb); B := a.base; m := *a.digits
  repeat
  { n := *b.digits
  if m < n then pr{"ERROR: base_B integer subtraction underflow"}
  else if m > n
  then b := base_B(B, catlist(list(m - n, 0), b.digits))
  else return base_B(b.base, ominus_digits(a.digits, b.digits, b.base)) }
end

# --- ominus_digits (md line 572) ---
procedure ominus_digits(a, b, B)
  local u, v, k, j
  u := copy(a)
  v := catlist(list(*a - *b, 0), copy(b))
  k := 0
  every j := *u to 1 by -1 do
  { u[j] := u[j] - v[j] + k
  if u[j] < 0 then { u[j] +:= B; k := -1 } else k := 0 }
  return normalize_digits(u)
end

# --- normalize_base_B (md line 616) ---
procedure normalize_base_B(r)
  d := normalize_digits(r.digits)
  return base_B(r.base, d)
end

# --- normalize_digits (md line 616) ---
procedure normalize_digits(d)
  while (*d > 1) & (d[1] = 0) do pop(d)
  return d
end

# --- times_base_B (md line 634) ---
procedure times_base_B(a, b)
  return base_B(a.base, times_digits(a.digits, b.digits, a.base))
end

# --- times_digits (md line 645) ---
procedure times_digits(a, b, B)
  local m, n, c, gamma, t, k, l
  m := *a
  n := *b
  c := list(m + n, 0)
  every k := 0 to n - 1 by 1 do
  {
  gamma := 0
  every l := 0 to m - 1 by 1 do
  {
  t := a[m - l] * b[n - k] + c[m + n - k - l] + gamma
  if t < 0
  then pr{"ERROR: Integer overflow in times_base_B, base = ", B}
  c[m + n - k - l] := mod_integer(t, B)
  gamma := t / B
  }
  c[n - k] := gamma
  }
  return normalize_digits(c)
end

# --- div_base_B (md line 704) ---
procedure div_base_B(a, b)
  return normalize_base_B(base_B(a.base, div_digits(a.digits, b.digits, a.base)))
end

# --- div_digits ---
procedure div_digits(a, b, B)
  local q, rr, du, u, v, n, m, d, j, qe, c, k
  # If the divisor is 0, then fail.
  if (*b = 1) & (b[1] = 0) then { pr{"ERROR: divide by 0 in base_B"}; fail }
  # If a is shorter than b, return 0.
  if *a < *b then return [0]
  if *b = 1 then {
    q := list(*a, 0)
    rr := 0
    every j := 1 to *a do {
      du := rr * B + a[j]
      q[j] := du / b[1]
      rr := du % b[1]
    }
    return normalize_digits(q)
  }
  u := copy(a)
  v := copy(b)
  n := *v
  m := *u - n
  q := list(m + 1, 0)
  d := B / (v[1] + 1)
  u := times_digits(u, [d], B)
  if *u = m + n then u := catlist([0], u)
  v := times_digits(v, [d], B)
  every j := 1 to m + 1 do {
    if u[j] = v[1] then qe := B - 1 else qe := ((u[j] * B) + u[j + 1]) / v[1]
    while (v[2] * qe) > (((u[j] * B) + u[j + 1] - (qe * v[1])) * B + u[j + 2]) do qe -:= 1
    c := 0
    every k := n to 1 by -1 do {
      du := u[j + k] - (qe * v[k]) + c
      u[j + k] := mod_integer(du, B)
      c := (du - u[j + k]) / B
    }
    u[j] +:= c
    q[j] := qe
    if u[j] < 0 then {
      qe -:= 1
      c := 0
      every k := n to 1 by -1 do {
        u[j + k] +:= v[k] + c
        if u[j + k] >= B then { u[j + k] -:= B; c := 1 }
        else c := 0
      }
      u[j] +:= c
    }
  }
  return normalize_digits(q)
end

# --- print_base_B (md line 892) ---
procedure print_base_B(b)
  writes(b.digits[1])
  every i := 2 to *b.digits do writes(" ", right(b.digits[i], Width, "0"))
  writes(" #", b.base, "#")
end

# --- less_base_B (md line 909) ---
procedure less_base_B(a, b)
  return less_digits(a.digits, b.digits)
end

# --- less_digits (md line 909) ---
procedure less_digits(a, b)
  if *a < *b then return
  else if (*a > *b) then fail
  else if *a = 0 then fail
  else if (a[1] > b[1]) then fail
  else if (a[1] < b[1]) then return
  else return less_digits(rest(a), rest(b))
end

# --- equal_base_B (md line 909) ---
procedure equal_base_B(a, b)
  return equal_digits(a.digits, b.digits)
end

# --- equal_digits (md line 909) ---
procedure equal_digits(a, b)
  if *a < *b then fail
  else if (*a > *b) then fail
  else if *a = 0 then return
  else if a[1] ~== b[1] then fail
  else return equal_digits(rest(a), rest(b))
end

# --- rest (md line 933) ---
procedure rest(x)
  if *x < 2 then return [] else return x[2:*x + 1]
end

record Z(sign, mantissa)

# --- zero_Z (md line 971) ---
procedure zero_Z(a)
  return Z(1, zero_base_B(a.mantissa))
end

# --- one_Z (md line 971) ---
procedure one_Z(a)
  return Z(1, one_base_B(a.mantissa))
end

# --- k_Z (md line 985) ---
procedure k_Z(x)
  initial set_base(10000, 4)
  return Z(if x = 0 then 1 else x/abs(x),
  base_B(Base, digits_of(abs(x), Base)))
end

# --- plus_Z (md line 1001) ---
procedure plus_Z(a, b)
  if negative_Z(a) & gt0_Z(b) then return plus_Z(b, a)
  if is_zero_Z(a) then return normalize_Z(b)
  if is_zero_Z(b) then return normalize_Z(a)
  if gt0_Z(a) & gt0_Z(b) then return normalize_Z(Z(a.sign, plus_base_B(a.mantissa, b.mantissa)))
  if negative_Z(a) & negative_Z(b) then return normalize_Z(Z(a.sign, plus_base_B(a.mantissa, b.mantissa)))
  if gt0_Z(a) & negative_Z(b) then {
    if less_base_B(a.mantissa, b.mantissa)
    then return normalize_Z(Z(-1, ominus_base_B(b.mantissa, a.mantissa)))
    else return normalize_Z(Z(1, ominus_base_B(a.mantissa, b.mantissa))) }
  return plus_Z(b, a)
end

# --- minus_Z (md line 1041) ---
procedure minus_Z(x)
  return normalize_Z(Z(-x.sign, x.mantissa))
end

# --- times_Z (md line 1072) ---
procedure times_Z(a, b)
  return normalize_Z(Z(a.sign * b.sign, times_base_B(a.mantissa, b.mantissa)))
end

# --- div_Z (synthesized) ---
procedure div_Z(a, b)
  return normalize_Z(Z(a.sign * b.sign, div_base_B(a.mantissa, b.mantissa)))
end

# --- mod_Z (md line 1104) ---
procedure mod_Z(a, b)
  return (if less_Z(b, zero_Z(b)) then mod_Z(a, minus_Z(b))
  else if less_Z(a, zero_Z(a))
  then plus_Z(a, minus_Z(times_Z(b, plus_Z(minus_Z(one_Z(a)), div_Z(a, b)))))
  else plus_Z(a, minus_Z(times_Z(b, div_Z(a, b))))
  )
end

# --- abs_Z (md line 1137) ---
procedure abs_Z(x)
  return Z(1, x.mantissa)
end

# --- deg_Z (md line 1148) ---
procedure deg_Z(x)
  return x
end

# --- normalize_Z (md line 1148) ---
procedure normalize_Z(z)
  if is_zero_Z(z) then return Z(1, z.mantissa)
  return z
end

# --- equal_Z (md line 1162) ---
procedure equal_Z(a, b)
  if is_zero_Z(a) & is_zero_Z(b) then return
  else if a.sign ~== b.sign then fail
  else return equal_base_B(a.mantissa, b.mantissa)
end

# --- less_Z (md line 1162) ---
procedure less_Z(a, b)
  if a.sign < b.sign then return
  if a.sign > b.sign then fail
  if a.sign = 1 then return less_base_B(a.mantissa, b.mantissa)
  if a.sign = -1 then return less_base_B(b.mantissa, a.mantissa)
end

# --- unit_Z (md line 1162) ---
procedure unit_Z(x)
  return (equal_Z(x, one_Z(x)) | equal_Z(x, Z(-1, one_base_B(x.mantissa))))
end

# --- gt0_Z (md line 1162) ---
procedure gt0_Z(x)
  if x.sign ~== 1 then fail
  if is_zero_Z(x) then fail
  return
end

# --- negative_Z (md line 1162) ---
procedure negative_Z(x)
  if x.sign ~== -1 then fail
  if is_zero_Z(x) then fail
  return
end

# --- is_zero_Z (md line 1162) ---
procedure is_zero_Z(x)
  return equal_base_B(x.mantissa, zero_base_B(x.mantissa))
end

# --- print_Z (md line 1187) ---
procedure print_Z(a)
  local digits, i
  if a.sign < 0 then writes("(-")
  digits := a.mantissa.digits
  writes(digits[1])
  every i := 2 to *digits do writes(right(digits[i], Width, "0"))
  writes("z")
  if a.sign < 0 then writes(")")
end

