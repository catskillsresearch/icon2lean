# --- mod (md line 213) ---
procedure mod(a, b)
  local x
  if (x := proc("mod_" || type(a), 2)(a, b)) then return x
  if less(b, zero(b)) then return mod(a, -(b))
  return normalize(
  if less(a, zero(a))
  then plus(a, times(b, plus(ominus(-(a), b), one(a))))
  else plus(a, -(times(b, div(a, b))))
  )
end

# --- rem (md line 279) ---
procedure rem(a, b)
  return (if (x := proc("rem_" || type(a), 2)(a, b)) then x
  else ominus(a, times(div(a, b), b)))
end

# --- normalize (md line 337) ---
procedure normalize(a)
  if (x := proc("normalize_" || type(a), 1)(a)) then return x
  return a
end

# --- exp (md line 353) ---
procedure exp(x, p)
  if p = 1 then return x
  else { result := one(x)
  u := copy(x); v := p
  running := u
  while v ~== 0 do
  { if v % 2 = 1 then result := times(result, running)
  running := times(running, running)
  v := v / 2 }
  return result }
end

