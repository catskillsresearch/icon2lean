procedure FFI(N, B, omega)
  local bx, C, ax
  bx := polynomialize(B)
  C := FFT(N, bx, div(one(omega), omega))
  ax := polynomialize(times_vector_scalar(C, Q(1, N)))
  return ax
end

# --- polynomialize (md line 2816) ---
procedure polynomialize(B)
  local r, i
  r := []; i := 0
  every b := !B do {
  if not(equal(b, zero(b))) then push(r, term(b, i))
  i +:= 1 }
  return poly(r)
end

# --- times_vector_scalar (md line 2832) ---
procedure times_vector_scalar(V, x)
  local R, i
  R := list(*V); i := 1
  every v := !V do { R[i] := times(V[i], x); i +:= 1 }
  return R
end

# --- NPSI (md line 2852) ---
procedure NPSI(at)
  local ax, xt, n
  ax := at.Poly
  xt := poly_of(zeroth_coef(ax))
  n := log2(*ax.terms)
  every k := 0 to n-1
  do xt := ominus(plus(xt, xt),
  times_poly(truncate(ax, 2 ^ (k + 1)), times_poly(xt, xt)))
  return tpower(truncate(xt, at.N), at.N)
end

# --- log2 (md line 2870) ---
procedure log2(x)
  local l
  l := 0
  while x > 1 do { x := x/2; l := l + 1 }
  return l
end
