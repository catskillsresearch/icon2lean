procedure DIOPHANTINE(a, b, c)
  local gst, g, x_1, y_1
  gst := EUCLID(a, b)
  g := gst[1]; t := gst[3]
  if not divides(g, c) then pr{"ERROR: Diophantine solution nonexistent"}
  else { if less(abs(b), abs(a))
  then { x_1 := CRA1(a, c, abs(b))
  y_1 := div(ominus(c, times(a, x_1)), b) }
  else { y_1 := CRA1(b, c, abs(a))
  x_1 := div(ominus(c, times(b, y_1)), a) }
  return [g, x_1, y_1] }
end

