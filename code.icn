# --- plus_Q (md line 1355) ---
procedure plus_Q(a, b)
  local zz, top
  top := plus(times(a.dividend, b.divisor), times(b.dividend, a.divisor))
  zz := zero(a.dividend)
  return if equal(top, zz) then Q(zz, one(a.dividend))
  else normalize_Q(Q(top, times(a.divisor, b.divisor)))
end

