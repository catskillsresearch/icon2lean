procedure CRA2(r, m, s, n)
  local c, sigma, U
  c := INVERSE(m, n)
  sigma := mod(times(ominus(s, r), c), n)
  U := plus(r, times(sigma, m))
  return U
end

# --- CRA (md line 2400) ---
procedure CRA(rm_list)
  local rms, rm, M, U, c, sigma, r, m
  rms := copy(rm_list)
  rm := pop(rms); r := rm[1]; m := rm[2]
  M := one(m)
  U := mod(r, m)
  every k := 1 to *rms do {
  M := times(M, m)
  rm := pop(rms); r := rm[1]; m := rm[2]
  c := INVERSE(M, m)
  sigma := mod(times(ominus(r, mod(U, m)), c), m)
  U := plus(U, times(sigma, M)) }
  return U
end

