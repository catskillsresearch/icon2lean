# --- test near md line 25 ---
procedure FFT(N, a(x), omega, A);
if N = 1
then
{ Basis. } A_0 := a_0
else
begin
{ Binary split. }
n := N/2
b(x) := sum_i=0^{n-1} a_2i x^i
c(x) := sum_i=0^{n-1} a_2i+1 x^i
{ Recursive calls. }
FFT(n, b(x), omega2, B)
FFT(n, c(x), omega2, C)
{ Combine. }
for k := 0 until n - 1 do
begin
A_k := B_k + omega_k times C_k
A_k+n := B_k - omega_k times C_k
end
end

